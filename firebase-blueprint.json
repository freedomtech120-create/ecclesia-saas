{
  "entities": {
    "Tenant": {
      "title": "Tenant (Church)",
      "description": "Represents a church organization which can have multiple branches.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "trial"] },
        "subscriptionTier": { "type": "string", "enum": ["free", "basic", "premium"] },
        "logoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "adminId": { "type": "string", "description": "The UID of the Church Administrator" }
      },
      "required": ["name", "slug", "adminId"]
    },
    "Branch": {
      "title": "Branch",
      "description": "A specific location/branch of a church.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "pastorId": { "type": "string", "description": "Assigned Pastor UID" }
      },
      "required": ["tenantId", "name"]
    },
    "User": {
      "title": "User",
      "description": "A user of the platform (Super Admin, Admin, Pastor, Worker, Member).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "tenantId": { "type": "string" },
        "role": { "type": "string", "enum": ["super-admin", "church-admin", "pastor", "worker", "member"] },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "branchIds": { "type": "array", "description": "Branches this user is associated with" }
      },
      "required": ["uid", "email", "role"]
    },
    "Member": {
      "title": "Member",
      "description": "A church member profile.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "current_branch_id": { "type": "string" },
        "previous_branch_id": { "type": "string" },
        "transfer_status": { "type": "string", "enum": ["none", "pending", "approved", "rejected", "cancelled"] },
        "date_joined_current_branch": { "type": "string", "format": "date-time" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "familyId": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "groupIds": { "type": "array", "description": "Ministries/Groups the member belongs to" }
      },
      "required": ["tenantId", "branchId", "firstName", "lastName"]
    },
    "Service": {
      "title": "Church Service",
      "description": "An event or standard service record.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["sunday-service", "midweek", "event", "special"] },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      }
    },
    "Staff": {
      "title": "Staff & Pastors",
      "description": "Leadership and workers directory for a church.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["pastor", "worker", "admin"] },
        "position": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "firstName", "lastName", "role"]
    },
    "Attendance": {
      "title": "Service Attendance",
      "description": "Headcount and statistics for a church service.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "serviceId": { "type": "string" },
        "totalCount": { "type": "number" },
        "menCount": { "type": "number" },
        "womenCount": { "type": "number" },
        "childrenCount": { "type": "number" },
        "firstTimersCount": { "type": "number" },
        "notes": { "type": "string" },
        "recordedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "branchId", "serviceId", "totalCount"]
    },
    "Visitation": {
      "title": "Member Visitation",
      "description": "Records of follow-up or pastoral visits to members.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "memberId": { "type": "string" },
        "visitorId": { "type": "string", "description": "UID of the person who conducted the visit" },
        "visitDate": { "type": "string", "format": "date-time" },
        "purpose": { "type": "string" },
        "outcome": { "type": "string" },
        "notes": { "type": "string" },
        "recordedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "branchId", "memberId", "visitDate"]
    },
    "MemberAttendance": {
      "title": "Member Attendance Status",
      "description": "Detailed attendance status for a specific member in a service.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "serviceId": { "type": "string" },
        "memberId": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "sick", "travel"] },
        "report": { "type": "string" },
        "recordedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "serviceId", "memberId", "status"]
    },
    "PublicForm": {
      "title": "Public Form",
      "description": "A shareable form for member registration, donations, or events.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["member-onboarding", "donation", "event-registration", "general"] },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "branchId", "title", "type"]
    },
    "FormResponse": {
      "title": "Form Response",
      "description": "Data submitted via a public form.",
      "type": "object",
      "properties": {
        "formId": { "type": "string" },
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "data": { "type": "object" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["formId", "tenantId", "data"]
    },
    "SMSConfig": {
      "title": "SMS Configuration",
      "description": "Settings for SMS API integration.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "provider": { "type": "string", "enum": ["twilio", "africastalking"] },
        "apiKey": { "type": "string" },
        "apiSecret": { "type": "string" },
        "senderId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "provider"]
    },
    "SMSLog": {
      "title": "SMS Log",
      "description": "Records of messages sent.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "recipientCount": { "type": "number" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" }
      }
    },
    "Group": {
      "title": "Church Group / Ministry",
      "description": "Departments or fellowship groups (e.g., Youth Ministry, Choir).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["ministry", "fellowship", "department", "other"] },
        "leaderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name", "category"]
    },
    "MemberTransfer": {
      "title": "Member Transfer",
      "description": "Records details of official member transfers between branch locations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "transfer_code": { "type": "string" },
        "member_id": { "type": "string" },
        "from_branch_id": { "type": "string" },
        "to_branch_id": { "type": "string" },
        "initiated_by": { "type": "string", "description": "User ID of pastor who initiated" },
        "approved_by": { "type": "string", "description": "User ID of pastor who approved" },
        "rejected_by": { "type": "string", "description": "User ID of pastor who rejected" },
        "transfer_reason": { "type": "string" },
        "rejection_reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "cancelled"] },
        "notes": { "type": "string" },
        "initiated_at": { "type": "string", "format": "date-time" },
        "approved_at": { "type": "string", "format": "date-time" },
        "rejected_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "member_id", "from_branch_id", "to_branch_id", "transfer_code", "status"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "History of activities and modifications to audit compliance.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "userId": { "type": "string" },
        "branchId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "userId", "action"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or transfer alerts directed to specific users or branches.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "title", "message", "read"]
    },
    "BranchLevel": {
      "title": "Branch Level Hierarchy",
      "description": "Configurable levels of branch structure.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "assessmentAmount": { "type": "number" },
        "eventObligations": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name", "assessmentAmount"]
    },
    "Assessment": {
      "title": "Central Assessment",
      "description": "Central Church assessments created by national office.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "frequency": { "type": "string", "enum": ["weekly", "monthly", "quarterly", "yearly", "one-time"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "assignType": { "type": "string", "enum": ["all", "branch-level", "region", "specific-branch"] },
        "assignValue": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "title", "amount", "frequency", "dueDate"]
    },
    "AssessmentPayment": {
      "title": "Assessment Payment",
      "description": "Proof of payment made by branches for assessments.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "assessmentId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "paymentReceiptUrl": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "branchId", "assessmentId", "amount", "status"]
    },
    "Event": {
      "title": "Church Event",
      "description": "National, Regional, District, Group, or local events with contribution parameters.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "eventType": { "type": "string", "enum": ["national", "regional", "district", "group", "local"] },
        "organizer": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "contributionAmount": { "type": "number" },
        "contribType": { "type": "string", "enum": ["fixed", "branch-level", "attendance-based", "percentage"] },
        "paymentDeadline": { "type": "string", "format": "date-time" },
        "approvalStatus": { "type": "string", "enum": ["draft", "pending_district", "pending_regional", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "title", "eventType", "startDate", "endDate", "approvalStatus"]
    },
    "EventContribution": {
      "title": "Event Contribution",
      "description": "Financial contribution tracks for branches responding to an event.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "eventId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "partial", "overdue"] },
        "paymentReceiptUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "branchId", "eventId", "amount", "status"]
    },
    "EventAttendance": {
      "title": "Event Attendance",
      "description": "Registers headcounts and detailed RSVP/attendance for events.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "eventId": { "type": "string" },
        "branchId": { "type": "string" },
        "memberId": { "type": "string" },
        "status": { "type": "string", "enum": ["registered", "attended", "absent"] },
        "createdAt": { "type": "string", "format": "date" }
      },
      "required": ["tenantId", "eventId", "status"]
    },
    "FeatureSettings": {
      "title": "Configurable Feature Toggle Settings",
      "description": "Tenant wide parameters to activate or deactivate modules.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "enableAssessments": { "type": "boolean" },
        "enableArrearsTracking": { "type": "boolean" },
        "enableAutoReminders": { "type": "boolean" },
        "enablePaymentRanking": { "type": "boolean" },
        "enableEventCalendar": { "type": "boolean" },
        "enableNationalCalendar": { "type": "boolean" },
        "enableRegionalCalendar": { "type": "boolean" },
        "enableDistrictCalendar": { "type": "boolean" },
        "enableGroupCalendar": { "type": "boolean" },
        "enableLocalCalendar": { "type": "boolean" },
        "enableEventContributions": { "type": "boolean" },
        "eventApprovalFlow": { "type": "string", "enum": ["none", "district", "regional", "national"] }
      },
      "required": ["tenantId"]
    },
    "PaymentTransaction": {
      "title": "Payment Transaction",
      "description": "Records details of official payment transaction reference submissions and verifications.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "transactionId": { "type": "string" },
        "assessmentId": { "type": "string" },
        "branchId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Under Review", "Approved", "Rejected", "Partial Payment", "Overdue"] },
        "submittedBy": { "type": "string" },
        "verifiedBy": { "type": "string" },
        "verificationNotes": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAccount": { "type": "string" },
        "paymentDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "transactionId", "assessmentId", "branchId", "amount", "paymentMethod", "status"]
    },
    "Receipt": {
      "title": "Receipt",
      "description": "Digital receipts generated on completed, approved assessment transactions.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "receiptNumber": { "type": "string" },
        "transactionId": { "type": "string" },
        "paymentId": { "type": "string" },
        "branchId": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "receiptNumber", "transactionId", "branchId", "generatedAt"]
    },
    "RefundRequest": {
      "title": "Refund Request",
      "description": "Branch requests for overpayment refunds on calculated central assessments.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "branchId": { "type": "string" },
        "branchName": { "type": "string" },
        "assessmentId": { "type": "string" },
        "assessmentTitle": { "type": "string" },
        "totalPaid": { "type": "number" },
        "targetAmount": { "type": "number" },
        "overpaidAmount": { "type": "number" },
        "provider": { "type": "string" },
        "account": { "type": "string" },
        "accountName": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "submittedBy": { "type": "string" },
        "submittedByUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "adminNotes": { "type": "string" },
        "processedBy": { "type": "string" },
        "processedByUid": { "type": "string" }
      },
      "required": ["tenantId", "branchId", "assessmentId", "overpaidAmount", "status"]
    }
  },
  "firestore": {
    "tenants": {
      "schema": "Tenant",
      "description": "Church organizations"
    },
    "tenants/{tenantId}/branches": {
      "schema": "Branch",
      "description": "Sub-collection of branches for a church"
    },
    "users": {
      "schema": "User",
      "description": "Platform users with multi-tenant context"
    },
    "members": {
      "schema": "Member",
      "description": "Church members (isolated by tenantId/branchId)"
    },
    "services": {
      "schema": "Service",
      "description": "Service schedule"
    },
    "staff": {
      "schema": "Staff",
      "description": "Church staff and pastors directory"
    },
    "attendance": {
      "schema": "Attendance",
      "description": "Service attendance records"
    },
    "visitations": {
      "schema": "Visitation",
      "description": "Member visitation logs"
    },
    "member_attendance": {
      "schema": "MemberAttendance",
      "description": "Individual member attendance for specific services"
    },
    "public_forms": {
      "schema": "PublicForm",
      "description": "Configurations for shareable forms"
    },
    "form_responses": {
      "schema": "FormResponse",
      "description": "Collected submissions from public forms"
    },
    "sms_configs": {
      "schema": "SMSConfig",
      "description": "SMS API credentials"
    },
    "sms_logs": {
      "schema": "SMSLog",
      "description": "History of outgoing SMS"
    },
    "groups": {
      "schema": "Group",
      "description": "Church ministries and departments"
    },
    "member_transfers": {
      "schema": "MemberTransfer",
      "description": "Relocation and transfer actions for members"
    },
    "audit_logs": {
      "schema": "AuditLog",
      "description": "System compliance trace logging"
    },
    "notifications": {
      "schema": "Notification",
      "description": "System alerts and notifications"
    },
    "branch_levels": {
      "schema": "BranchLevel",
      "description": "Levels of branches (District, Regional, etc.) with billing assessment parameters"
    },
    "assessments": {
      "schema": "Assessment",
      "description": "Assessments initiated by central/headquarters"
    },
    "assessment_payments": {
      "schema": "AssessmentPayment",
      "description": "Payments and receipts submitted by branches against assessments"
    },
    "events": {
      "schema": "Event",
      "description": "National, Regional, District, Group, or local events"
    },
    "event_contributions": {
      "schema": "EventContribution",
      "description": "Payments and allocations for event specific contributions"
    },
    "event_attendance": {
      "schema": "EventAttendance",
      "description": "RSVP listing for events"
    },
    "feature_settings": {
      "schema": "FeatureSettings",
      "description": "Feature toggles activation controls"
    },
    "paymentTransactions": {
      "schema": "PaymentTransaction",
      "description": "Payment transactions submitted by branches and verified by admins."
    },
    "receipts": {
      "schema": "Receipt",
      "description": "Generated digital receipts for approved payments"
    },
    "refund_requests": {
      "schema": "RefundRequest",
      "description": "Refund requests submitted by branches and evaluated by HQ Treasury admins."
    }
  }
}
