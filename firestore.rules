rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function hasUserData() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Cached function for user data
    function getUserData() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; 
    }
    
    function isSuperAdmin() { 
      return isSignedIn() && (request.auth.token.email == 'freedomtech120@gmail.com' || (hasUserData() && getUserData().get('role', 'guest') == 'super-admin')); 
    }
    function isPastor() { 
      return isSignedIn() && (hasUserData() && getUserData().get('role', 'guest') == 'pastor'); 
    }
    function isAdmin() { 
      return isSignedIn() && (isSuperAdmin() || (hasUserData() && getUserData().get('role', 'guest') in ['church-admin', 'super-admin'])); 
    }
    
    function belongsToTenant(tenantId) { 
      return isSignedIn() && (isSuperAdmin() || (hasUserData() && getUserData().get('tenantId', '') == tenantId)); 
    }

    // --- Validation Helpers ---
    function isValidGroup(data) {
      return hasUserData() && (data.tenantId == getUserData().get('tenantId', '')) &&
             (!data.keys().hasAny(['name']) || (data.name is string && data.name.size() <= 100));
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || belongsToTenant(resource.data.tenantId));
      allow list: if isSignedIn() && (isSuperAdmin() || belongsToTenant(resource.data.tenantId));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'tenantId'])) ||
        isSuperAdmin() ||
        (isAdmin() && belongsToTenant(resource.data.tenantId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId']))
      );
    }

    // 2. Tenants Collection
    match /tenants/{tenantId} {
      allow get: if true; // Public church profile
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() && belongsToTenant(tenantId);
    }

    // 3. Branches Collection
    match /branches/{branchId} {
      allow get, list: if true; // Public access for location info 
      allow create: if isAdmin() && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if isAdmin() && belongsToTenant(resource.data.tenantId);
    }

    // 4. Members Collection
    match /members/{memberId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if (isSignedIn() && belongsToTenant(request.resource.data.tenantId)) ||
                    (request.resource.data.source == 'public-form' && request.resource.data.status == 'pending');
      allow update: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow delete: if isAdmin() && belongsToTenant(resource.data.tenantId);
    }

    // 5. Staff Collection
    match /staff/{staffId} {
      allow get, list: if isSignedIn() && (belongsToTenant(resource.data.tenantId) || resource.data.email == request.auth.token.email);
      allow create, update, delete: if isAdmin() && belongsToTenant(request.resource.data.tenantId);
    }

    // 6. Finances Collection
    match /finances/{recordId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if isAdmin() && belongsToTenant(resource.data.tenantId);
    }

    // 7. Services Collection
    match /services/{serviceId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create, update, delete: if (isAdmin() || isPastor()) && belongsToTenant(request.resource.data.tenantId);
    }

    // 8. Visitations Collection
    match /visitations/{visitationId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create, update: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
    }

    // 9. Attendance Collection
    match /attendance/{attendanceId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create, update: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
    }

    // 10. Member Attendance Collection
    match /member_attendance/{docId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update: if isSignedIn() && belongsToTenant(resource.data.tenantId) && belongsToTenant(request.resource.data.tenantId);
      allow delete: if isSignedIn() && belongsToTenant(resource.data.tenantId);
    }

    // 11. Staff Claims
    match /staff_claims/{email} {
      allow get: if true;
      allow write: if isAdmin();
    }

    // 12. Public Forms
    match /public_forms/{formId} {
      allow get: if true;
      allow list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create, update, delete: if (isAdmin() || isPastor()) && belongsToTenant(request.resource.data.tenantId);
    }

    // 13. Form Responses
    match /form_responses/{responseId} {
      allow create: if true;
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
    }
    
    // 14. SMS Configs
    match /sms_configs/{configId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if (isAdmin() || isPastor()) && belongsToTenant(request.resource.data.tenantId);
      allow update: if (isAdmin() || isPastor()) && belongsToTenant(resource.data.tenantId) && belongsToTenant(request.resource.data.tenantId);
      allow delete: if (isAdmin() || isPastor()) && belongsToTenant(resource.data.tenantId);
    }

    // 15. SMS Logs
    match /sms_logs/{logId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
    }

    // 16. SMS Templates
    match /sms_templates/{templateId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update: if isSignedIn() && belongsToTenant(resource.data.tenantId) && belongsToTenant(request.resource.data.tenantId);
      allow delete: if isSignedIn() && belongsToTenant(resource.data.tenantId);
    }

    // --- SMS Credit Reseller Collections ---
    match /gateway_settings/{settingId} {
      allow read, write: if isSuperAdmin();
    }

    match /sms_packages/{packageId} {
      allow read, list: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /sms_transactions/{transactionId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isSuperAdmin());
      allow update, delete: if isSuperAdmin();
    }

    match /wallet_transactions/{transactionId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isSuperAdmin(); // Wallets can only be charged server-side or via admin
      allow update, delete: if isSuperAdmin();
    }

    match /delivery_reports/{reportId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isSuperAdmin());
      allow update, delete: if isSuperAdmin();
    }

    // 17. Groups Collection
    match /groups/{groupId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if (isAdmin() || isPastor()) && belongsToTenant(request.resource.data.tenantId) && isValidGroup(request.resource.data);
      allow update, delete: if (isAdmin() || isPastor()) && belongsToTenant(resource.data.tenantId);
    }

    // 18. Member Transfers Collection
    match /member_transfers/{transferId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow delete: if isSuperAdmin();
    }

    // 19. Audit Logs Collection
    match /audit_logs/{logId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
    }

    // 20. Notifications Collection
    match /notifications/{notifyId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update: if isSignedIn() && belongsToTenant(resource.data.tenantId);
    }

    // 21. Subscription Transactions Collection
    match /subscription_transactions/{transactionId} {
      allow get: if isSignedIn() && (belongsToTenant(resource.data.tenantId) || isSuperAdmin());
      allow list: if isSuperAdmin() || (isSignedIn() && belongsToTenant(resource.data.tenantId));
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if isSuperAdmin();
    }

    // 22. Branch Levels Hierarchy Collection
    match /branch_levels/{levelId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if (isAdmin() || isSuperAdmin()) && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if (isAdmin() || isSuperAdmin()) && belongsToTenant(resource.data.tenantId);
    }

    // 23. Assessments Collection
    match /assessments/{assessmentId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if (isAdmin() || isSuperAdmin()) && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if (isAdmin() || isSuperAdmin()) && belongsToTenant(resource.data.tenantId);
    }

    // 24. Assessment Payments Collection
    match /assessment_payments/{paymentId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if (isAdmin() || isSuperAdmin()) && belongsToTenant(resource.data.tenantId);
    }

    // 25. Events Collection
    match /events/{eventId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow delete: if (isAdmin() || isSuperAdmin()) && belongsToTenant(resource.data.tenantId);
    }

    // 26. Event Contributions Collection
    match /event_contributions/{contributionId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow delete: if (isAdmin() || isSuperAdmin()) && belongsToTenant(resource.data.tenantId);
    }

    // 27. Event Attendance RSVP Collection
    match /event_attendance/{attendanceId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if isSignedIn() && belongsToTenant(resource.data.tenantId);
    }

    // 28. Configurable Feature Toggle Settings Collection
    match /feature_settings/{settingsId} {
      allow get, list: if isSignedIn() && belongsToTenant(settingsId);
      allow create: if isSignedIn() && belongsToTenant(settingsId) && request.resource.data.tenantId == settingsId;
      allow update: if (isAdmin() || isSuperAdmin()) && belongsToTenant(settingsId);
    }

    // 29. Payment Transactions Collection
    match /paymentTransactions/{transactionId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if isSignedIn() && belongsToTenant(resource.data.tenantId);
    }

    // 30. Receipts Collection
    match /receipts/{receiptId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if (isAdmin() || isSuperAdmin()) && belongsToTenant(resource.data.tenantId);
    }

    // 31. Refund Requests Collection
    match /refund_requests/{refundId} {
      allow get, list: if isSignedIn() && belongsToTenant(resource.data.tenantId);
      allow create: if isSignedIn() && belongsToTenant(request.resource.data.tenantId);
      allow update: if isSignedIn() && belongsToTenant(resource.data.tenantId) && (isAdmin() || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }
  }
}
